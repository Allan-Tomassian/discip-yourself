APP_ENV=local
PORT=3001
SUPABASE_URL=https://example-project-ref.supabase.co
SUPABASE_SECRET_KEY=<server-only-supabase-service-role-key>
# Legacy alias still supported if your platform uses it instead of SUPABASE_SECRET_KEY.
# SUPABASE_SERVICE_ROLE_KEY=<server-only-supabase-service-role-key>
OPENAI_API_KEY=<server-only-openai-key>
OPENAI_MODEL=gpt-4.1-mini
OPENAI_DEFAULT_TIMEOUT_MS=20000
# Optional model-class routing overrides. Route-specific vars below still win.
# AI_MODEL_FAST_LOW_COST_TEXT=gpt-4.1-mini
# AI_MODEL_STRUCTURED_JSON_SMALL=gpt-4.1-mini
# AI_MODEL_REASONING_MEDIUM=gpt-4.1-mini
# AI_MODEL_REASONING_DEEP=gpt-5.4
# AI_MODEL_PREMIUM_DEEP_ANALYSIS=gpt-5.4
# AI_MODEL_MULTIMODAL_VISION=gpt-5.4
# AI_MODEL_DOCUMENT_SUMMARY=gpt-4.1-mini
# AI_TIMEOUT_FAST_LOW_COST_TEXT_MS=15000
# AI_TIMEOUT_STRUCTURED_JSON_SMALL_MS=10000
# AI_TIMEOUT_REASONING_MEDIUM_MS=35000
# AI_TIMEOUT_REASONING_DEEP_MS=60000
# AI_TIMEOUT_PREMIUM_DEEP_ANALYSIS_MS=65000
# AI_TIMEOUT_MULTIMODAL_VISION_MS=60000
# AI_TIMEOUT_DOCUMENT_SUMMARY_MS=45000
SESSION_GUIDANCE_PREPARE_OPENAI_MODEL=gpt-5.4
SESSION_GUIDANCE_PREPARE_OPENAI_TIMEOUT_MS=60000
AI_QUOTA_MODE=normal
# Only effective in local/test. Allows http://localhost, http://127.0.0.1, private LAN IPv4, and http://*.local origins.
CORS_ALLOW_PRIVATE_NETWORK_DEV=false
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=info
