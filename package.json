{
  "name": "discip-yourself",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "cap:open:ios": "npx cap open ios",
    "cap:sync": "npm run build && npx cap sync",
    "dev": "vite --port 5173 --strictPort --host 127.0.0.1",
    "dev:lan": "vite --port 5173 --strictPort --host 0.0.0.0",
    "dev:5174": "vite --port 5174 --strictPort --host 127.0.0.1",
    "dev:lan:5174": "vite --port 5174 --strictPort --host 0.0.0.0",
    "build": "vite build",
    "lint": "eslint src --ext .js,.jsx",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "preview": "vite preview --port 4174 --strictPort --host 127.0.0.1",
    "preview:lan": "vite preview --port 4174 --strictPort --host 0.0.0.0",
    "test": "npm run ui:check:menu && npm run ui:check:pages && vitest run src",
    "test:unit": "vitest run src",
    "test:e2e": "playwright test",
    "check:da": "node scripts/check-da.js",
    "check:env:public": "node scripts/check-no-public-secrets.mjs",
    "ui:audit": "node scripts/ui-audit-scan.mjs && node scripts/ui-audit-report.mjs",
    "ui:audit:uniformity": "node scripts/ui-uniformity-scan.mjs && node scripts/ui-uniformity-report.mjs",
    "ui:audit:text": "node scripts/text-audit-scan.mjs && node scripts/text-audit-report.mjs",
    "ui:audit:lot10": "npm run ui:audit:uniformity && npm run ui:audit:text",
    "ui:report": "node scripts/ui-audit-report.mjs",
    "ui:check": "node scripts/check-no-legacy-ui.mjs",
    "ui:check:menu": "node scripts/check-no-legacy-ui.mjs --scope src/components/TopNav.jsx,src/components/TopMenuPopover.jsx,src/features/navigation/topMenuGate.css",
    "ui:check:pages": "node scripts/check-no-legacy-ui.mjs --scope src/pages/Account.jsx,src/pages/Preferences.jsx,src/pages/Subscription.jsx,src/pages/Data.jsx,src/pages/Privacy.jsx,src/pages/Terms.jsx,src/pages/Support.jsx",
    "ui:check:strict": "node scripts/check-no-legacy-ui.mjs --scope src/pages/Home.jsx,src/pages/Categories.jsx,src/pages/Pilotage.jsx,src/ui/focus/FocusCard.jsx,src/ui/today/MicroActionsCard.jsx,src/ui/calendar/CalendarCard.jsx,src/pages/CategoryView.jsx,src/components/EditItemPanel.jsx,src/App.jsx",
    "check": "npm run check:env:public && npm run lint && npm run build && npm run test"
  },
  "dependencies": {
    "@capacitor/cli": "^6.1.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/ios": "^6.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@supabase/supabase-js": "^2.95.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.2.4",
    "vitest": "^1.6.0"
  }
}
