VITE_APP_ENV=local
VITE_SUPABASE_URL=https://example-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_placeholder_frontend_key

# Local Vite dev sends Discip Yourself backend calls to /api and lets Vite proxy them.
VITE_DEV_API_PROXY_TARGET=https://discip-yourself-backend.onrender.com
# Optional: set VITE_USE_DEV_API_PROXY=false to bypass /api and call VITE_AI_BACKEND_URL directly.

# Production/preview backend base URL. In Vite dev this is used only when the dev proxy is disabled.
VITE_AI_BACKEND_URL=https://discip-yourself-backend.onrender.com
# Legacy direct-local-backend mode when VITE_USE_DEV_API_PROXY=false:
# VITE_AI_BACKEND_PORT=3001
